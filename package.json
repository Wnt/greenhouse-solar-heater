{
  "name": "greenhouse-solar-heater",
  "version": "1.0.0",
  "private": true,
  "description": "Solar thermal greenhouse heating system — specs, simulation, and tools",
  "scripts": {
    "test": "node --test 'tests/**/*.test.js' 'tests/**/*.test.mjs' && npx playwright test",
    "test:unit": "node --test 'tests/**/*.test.js' 'tests/**/*.test.mjs'",
    "test:e2e": "npx playwright test",
    "screenshots": "npx playwright test --config=playwright.screenshots.config.js",
    "diagram": "node design/diagrams/generate-topology.js",
    "topology-pdf": "node design/docs/pdf/generate-topology-pdf.js",
    "topology-svg": "node design/docs/pdf/generate-topology-svg.js",
    "topology-contrast": "node design/docs/pdf/check-contrast.js design/diagrams/system-topology.drawio",
    "topology-svg-playground": "node design/docs/pdf/generate-topology-svg.js --theme playground --output playground/assets/system-topology.svg",
    "topology-drawio-playground": "node design/diagrams/generate-topology.js --theme playground --output playground/assets/system-topology.drawio",
    "bootstrap-history": "node scripts/generate-bootstrap-history.mjs",
    "knip": "knip",
    "check:file-size": "node scripts/check-file-size.mjs",
    "check:assets": "node scripts/check-unused-assets.mjs",
    "lint:debt": "npm run check:file-size && npm run knip && npm run check:assets"
  },
  "devDependencies": {
    "@playwright/test": "1.56.0",
    "acorn": "^8.16.0",
    "js-yaml": "^4.1.1",
    "knip": "^6.6.1",
    "serve": "^14.2.6"
  },
  "overrides": {
    "@emnapi/core": "^1.10.0",
    "@emnapi/runtime": "^1.10.0"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.700.0",
    "@opentelemetry/api": "^1.9.0",
    "@opentelemetry/api-logs": "^0.213.0",
    "@opentelemetry/auto-instrumentations-node": "^0.72.0",
    "@opentelemetry/exporter-logs-otlp-http": "^0.213.0",
    "@opentelemetry/exporter-metrics-otlp-http": "^0.213.0",
    "@opentelemetry/exporter-trace-otlp-http": "^0.213.0",
    "@opentelemetry/resources": "^2.7.0",
    "@opentelemetry/sdk-logs": "^0.215.0",
    "@opentelemetry/sdk-metrics": "^2.7.0",
    "@opentelemetry/sdk-node": "^0.213.0",
    "@simplewebauthn/server": "^13.3.0",
    "mqtt": "^5.15.1",
    "pg": "^8.20.0",
    "web-push": "^3.6.7",
    "ws": "^8.20.0"
  }
}
