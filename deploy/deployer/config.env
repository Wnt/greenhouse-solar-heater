# Mutable service configuration — managed by the deployer image.
# Changes to this file deploy automatically via the CD pipeline.
#
# WARNING: Do NOT add secrets here (SESSION_SECRET, S3 credentials, etc.).
# Secrets live in .env.secrets, written by cloud-init at server provision time.
#
# To add a new variable: add it here, commit, push. The deployer applies it
# on the next cycle (~5 min). No server recreation needed.

PORT=3000
AUTH_ENABLED=true
RPID=greenhouse.madekivi.fi
ORIGIN=https://greenhouse.madekivi.fi
DOMAIN=greenhouse.madekivi.fi
GITHUB_REPO=owner/greenhouse-solar-heater
VPN_CHECK_HOST=
VPN_CONFIG_KEY=wg0.conf
SETUP_WINDOW_MINUTES=30
NODE_ENV=production
COMPOSE_PROFILES=
CONTROLLER_IP=
CONTROLLER_SCRIPT_ID=
VAPID_SUBJECT=
