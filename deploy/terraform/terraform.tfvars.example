# SSH public key — required by UpCloud cloud-init templates (SSH port is NOT exposed)
ssh_public_key = "ssh-ed25519 AAAA..."

# Domain name for the monitoring UI
domain = "greenhouse.madekivi.fi"

# GitHub repository for GHCR image (owner/name format)
github_repo = "Wnt/greenhouse-solar-heater"

# Session secret for signed cookies (generate with: openssl rand -hex 32)
session_secret = "REPLACE_ME"

# UpCloud zone (default: fi-hel1 = Helsinki)
# upcloud_zone = "fi-hel1"

# UpCloud server plan (default: DEV-1xCPU-1GB-10GB, €3/month, limit 2 per account)
# server_plan = "DEV-1xCPU-1GB-10GB"

# Object Storage region (default: europe-1)
# objsto_region = "europe-1"

# Enable WireGuard VPN (default: false — enable when ready for on-site device access)
# enable_vpn = false

# Required environment variable (not in tfvars for security):
#   export UPCLOUD_TOKEN="your-api-token"
#
# Create an API token in UpCloud Control Panel > Account > API Tokens.
# See: https://upcloud.com/docs/guides/managing-api-tokens/
#
# After `terraform apply`, note the server_ip output and create
# an A record in your DNS pointing your domain to that IP.
