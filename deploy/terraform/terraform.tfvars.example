# SSH public key for worker node access (optional — leave commented out to disable)
# ssh_public_key = "ssh-ed25519 AAAA..."

# Domain name for the monitoring UI
domain = "greenhouse.madekivi.fi"

# GitHub repository for GHCR image (owner/name format)
github_repo = "Wnt/greenhouse-solar-heater"

# Session secret for signed cookies (generate with: openssl rand -hex 32)
session_secret = "REPLACE_ME"

# Shelly Cloud refresh token (60-day) for device-name automation.
# Obtain via the DevTools console one-liner in scripts/rename-cloud-devices.mjs.
# Leave empty to disable cloud renaming; deploy + sensor remap will log a warning
# with instructions.
# shelly_cloud_refresh_token = ""
# shelly_cloud_api_url       = "https://shelly-249-eu.shelly.cloud"

# UpCloud zone (default: fi-hel1 = Helsinki)
# upcloud_zone = "fi-hel1"

# Object Storage region (default: europe-1)
# objsto_region = "europe-1"

# Kubernetes version (default: 1.32)
# k8s_version = "1.32"

# Worker node plan (default: DEV-1xCPU-1GB-10GB, ~€3/month)
# node_plan = "DEV-1xCPU-1GB-10GB"

# Number of worker nodes (default: 1)
# node_count = 1

# Restrict Kubernetes API access to your IP (REQUIRED — no default, must be set)
# Find your IP: curl -s ifconfig.me
control_plane_ip_filter = ["your.public.ip/32"]

# Restrict OpenVPN (UDP 1194) to your IoT/home network's public IP (REQUIRED)
# Enforced via CiliumNetworkPolicy — port 1194 is invisible to all other IPs
vpn_allowed_cidrs = ["your.home.network.ip/32"]

# Required environment variable (not in tfvars for security):
#   export UPCLOUD_TOKEN="your-api-token"
#
# Create an API token in UpCloud Control Panel > Account > API Tokens.
# See: https://upcloud.com/docs/guides/managing-api-tokens/
#
# After `terraform apply`, get the kubeconfig:
#   terraform output -raw kubeconfig > ~/.kube/config
#
# OpenVPN config file path (download from S3 first — see one-liner below)
# openvpn_config_file = "openvpn.conf"

# Get the worker node's public IP for your DNS A record:
#   eval $(terraform output -raw worker_node_ip_command)
